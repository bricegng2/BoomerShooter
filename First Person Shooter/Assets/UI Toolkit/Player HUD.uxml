        <ui:VisualElement name="Guns" style="flex-grow: 1; width: 403px; min-width: 200px; max-width: none; position: absolute; right: auto; height: 163px; min-height: 163px; max-height: 163px; flex-direction: row; align-self: auto; align-items: stretch; top: auto; justify-content: center; align-content: center; left: 113px;">
            <ui:VisualElement name="PistolIcon" style="flex-grow: 1; background-color: rgb(242, 169, 0); height: 76px; width: 76px; min-width: 76px; max-width: 76px; max-height: 76px; min-height: 76px; margin-top: 7px; margin-right: 7px; margin-bottom: 7px; margin-left: 7px; top: 23%; align-self: auto; justify-content: center;">
